{
  "name": "gorth-base-primitive",
  "version": "1.1.4",
  "description": "Shared shadcn-based UI package",
  "type": "module",
  "author": "Gorthenburg",
  "license": "GORTH",
  "private": true,
  "keywords": [
    "gorth",
    "shadcn",
    "ui",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/goraria/gorth-ui.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/globals.css",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cores/lucide": {
      "types": "./dist/cores/lucide.d.ts",
      "import": "./dist/cores/lucide.js"
    },
    "./cores/*": {
      "types": "./dist/cores/*.d.ts",
      "import": "./dist/cores/*.js",
      "require": "./dist/cores/*.cjs"
    },
    "./cores/*/*": {
      "types": "./dist/cores/*/*.d.ts",
      "import": "./dist/cores/*/*.js",
      "require": "./dist/cores/*/*.cjs"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    },
    "./modules/*": {
      "types": "./dist/modules/*.d.ts",
      "import": "./dist/modules/*.js"
    },
    "./default/*": {
      "types": "./dist/components/ui/*.d.ts",
      "import": "./dist/components/ui/*.js"
    },
    "./pattern/*": {
      "types": "./dist/components/io/*.d.ts",
      "import": "./dist/components/io/*.js"
    },
    "./layouts/*": {
      "types": "./dist/layouts/*.d.ts",
      "import": "./dist/layouts/*.js"
    },
    "./providers/*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js"
    },
    "./block/*": {
      "types": "./dist/components/block/*.d.ts",
      "import": "./dist/components/block/*.js"
    },
    "./custom/*": {
      "types": "./dist/components/custom/*.d.ts",
      "import": "./dist/components/custom/*.js"
    },
    "./background/*": {
      "types": "./dist/components/background/*.d.ts",
      "import": "./dist/components/background/*.js"
    },
    "./element/*": {
      "types": "./dist/components/element/*.d.ts",
      "import": "./dist/components/element/*.js"
    },
    "./dashboard/*": {
      "types": "./dist/components/dashboard/*.d.ts",
      "import": "./dist/components/dashboard/*.js"
    },
    "./assets/*": "./src/assets/*",
    "./globals.css": "./dist/globals.css",
    "./postcss.config": "./postcss.config.mjs"
  },
  "files": [
    "dist",
    "src/assets"
  ],
  "scripts": {
    "build": "tsup && pnpm exec tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css --minify",
    "buildprepack": "pnpm build",
    "prepack": "pnpm build",
    "update": "pnpm update",
    "er": "tsup && node ./scripts/copy-assets.mjs && pnpm exec tailwindcss -i ./src/styles/globals.css -o ./dist/globals.css --minify",
    "dev": "tsup --watch",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "shadcn": "pnpm dlx shadcn@latest add -a -o",
    "shadcn:ui": "pnpm dlx shadcn@latest add -o -p src/components/ui",
    "shadcn:ui:all": "pnpm dlx shadcn@latest add -a -o -p src/components/ui",
    "shadcn:io": "pnpm dlx shadcn@latest add -o -p src/components/io",
    "shadcn:ui:list": "bash ./scripts/shadcn-ui-list.sh",
    "shadcn:io:list": "bash ./scripts/shadcn-io-list.sh",
    "shadcn:io:backgrounds": "bash ./scripts/shadcn-io-backgrounds.sh",
    "shadcn:io:hooks": "bash ./scripts/shadcn-io-hooks.sh"
  },
  "dependencies": {
    "@shadcn/react": "^0.2.1",
    "@tanstack/react-form": "^1.33.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-ranger": "^0.0.5",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "ai": "^7.0.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.42.2",
    "fs-extra": "^11.3.6",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "media-chrome": "^4.19.2",
    "motion": "^12.42.2",
    "radix-ui": "^1.6.2",
    "react-day-picker": "^10.0.1",
    "react-dropzone": "^15.0.0",
    "react-fast-marquee": "^1.6.5",
    "react-image-crop": "^11.1.2",
    "react-medium-image-zoom": "^5.4.8",
    "react-resizable-panels": "^4.12.1",
    "react-svg-credit-card-payment-icons": "^6.0.4",
    "react-use-measure": "^2.1.7",
    "recharts": "3.9.2",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "simplex-noise": "^4.0.3",
    "sonner": "^2.0.7",
    "swr": "^2.4.2",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "eslint": "^9.39.4",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.33.4"
}
